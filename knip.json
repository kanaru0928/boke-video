{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "frontend": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts", "src/**/*.d.ts"]
    },
    ".": {
      "entry": ["package.json", "lefthook.yml"],
      "project": ["*.json", "*.yaml", "*.yml"]
    }
  },
  "ignoreDependencies": ["wrangler"],
  "ignoreBinaries": [
    "go",
    "gofmt",
    "scripts/local-backend.sh",
    "scripts/local-dev.sh",
    "scripts/local-frontend.sh",
    "scripts/setup-local-sample-stream.sh",
    "scripts/start-local-dummy-stream.sh"
  ]
}
