{
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "backend:check": "cd backend && gofmt -w ./cmd ./internal && go test ./...",
    "backend:lint": "cd backend && go vet ./...",
    "check": "biome check . && knip && pnpm --dir frontend run typecheck && pnpm --dir frontend run test && pnpm --dir frontend run build && pnpm backend:lint && pnpm backend:check",
    "dev": "scripts/local-dev.sh",
    "demo:backend": "scripts/local-backend.sh",
    "demo:frontend": "scripts/local-frontend.sh",
    "demo:browser-smoke": "node scripts/local-browser-smoke-test.mjs",
    "demo:smoke": "node scripts/local-smoke-test.mjs",
    "deploy:frontend": "pnpm --dir frontend run deploy",
    "format": "biome format --write . && gofmt -w backend/cmd backend/internal",
    "hooks:install": "lefthook install",
    "lint": "biome lint . && knip && pnpm backend:lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.59.1",
    "knip": "^5.88.1",
    "lefthook": "^2.1.6"
  }
}
