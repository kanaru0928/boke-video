{
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "backend:format": "cd backend && gofmt -w ./cmd ./internal",
    "backend:deploy": "scripts/deploy-backend.sh",
    "backend:test": "cd backend && go test ./...",
    "backend:vet": "cd backend && go vet ./...",
    "check": "pnpm run knip && pnpm --dir frontend run typecheck && pnpm --dir frontend run test && pnpm --dir frontend run build && pnpm run backend:vet && pnpm run backend:test",
    "dev": "pnpm env:sync:local && scripts/local-dev.sh",
    "env:sync:local": "node scripts/env-sync.mjs local",
    "env:sync:production": "node scripts/env-sync.mjs production",
    "hooks:install": "lefthook install",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "knip": "^5.88.1",
    "lefthook": "^2.1.6"
  }
}
